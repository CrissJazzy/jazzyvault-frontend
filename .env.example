# ==========================================
# JazzyVault Frontend — Environment Variables
# ==========================================
# Copy this file to .env.local for local development.
# In Netlify: Site Settings → Environment Variables → add each key below.

# --- Supabase ---
# Found in Supabase Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# --- Backend API ---
# Local dev: http://localhost:8000
# Production: your Render backend URL, e.g. https://jazzyvault-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- App Metadata ---
NEXT_PUBLIC_APP_NAME=JazzyVault
NEXT_PUBLIC_APP_URL=http://localhost:3000
